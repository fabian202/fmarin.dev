---
interface Props {
  translations: {
    langs: string;
    spanish: string;
    english: string;
    native: string;
    advanced: string;
  };
}

const { translations } = Astro.props;
---

<div class="lang-section">
  <div class="section-header">
    <span class="section-num">05</span>
    <h2>{translations.langs}</h2>
  </div>
  <div class="lang-item">
    <div class="lang-name">{translations.spanish}</div>
    <div class="lang-level">{translations.native}</div>
  </div>
  <div class="lang-item">
    <div class="lang-name">{translations.english}</div>
    <div class="lang-level">{translations.advanced}</div>
  </div>
</div>
