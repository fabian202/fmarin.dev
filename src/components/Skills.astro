---
import type { CollectionEntry } from 'astro:content';

interface Props {
  skills: CollectionEntry<'skills'>[];
  translations: {
    skills: string;
  };
}

const { skills, translations } = Astro.props;
---

<section class="skills-section" id="skills">
  <div class="section-header">
    <span class="section-num">01</span>
    <h2>{translations.skills}</h2>
  </div>
  <div class="skills-grid">
    {skills.map((skill) => (
      <div class="skill-card">
        <div class="skill-icon">{skill.data.category}</div>
        <div class="skill-title">{skill.data.title}</div>
        <div class="skill-tags">
          {skill.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
