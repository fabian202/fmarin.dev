---
import type { CollectionEntry } from 'astro:content';

interface Props {
  highlights: CollectionEntry<'highlights'>[];
  translations: {
    highlights: string;
  };
}

const { highlights, translations } = Astro.props;
---

<section class="highlights-section" id="highlights">
  <div class="section-header">
    <span class="section-num">03</span>
    <h2>{translations.highlights}</h2>
  </div>
  <div class="highlights-list">
    {highlights.map((highlight) => (
      <div class="highlight-item">
        <div class="highlight-title">{highlight.data.title}</div>
        <div class="highlight-desc">{highlight.data.description}</div>
      </div>
    ))}
  </div>
</section>
