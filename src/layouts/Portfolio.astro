---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import enTranslations from '../i18n/en.json';
import esTranslations from '../i18n/es.json';

const { lang = 'en' } = Astro.props as { lang: 'en' | 'es' };

const experience = await getCollection('experience', ({ id }: { id: string }) =>
  id.startsWith(`${lang}/`)
);
const skills = await getCollection('skills', ({ id }: { id: string }) =>
  id.startsWith(`${lang}/`)
);
const education = await getCollection('education', ({ id }: { id: string }) =>
  id.startsWith(`${lang}/`)
);

const expOrdered = experience.sort((a: CollectionEntry<'experience'>, b: CollectionEntry<'experience'>) => a.data.order - b.data.order);
const skillsOrdered = skills.sort((a: CollectionEntry<'skills'>, b: CollectionEntry<'skills'>) => a.data.order - b.data.order);
const educationOrdered = education.sort((a: CollectionEntry<'education'>, b: CollectionEntry<'education'>) => a.data.order - b.data.order);

const otherLang = lang === 'en' ? 'es' : 'en';
const otherUrl  = lang === 'en' ? '/es' : '/';
const currentYear = new Date().getFullYear();

const ui = {
  en: enTranslations,
  es: esTranslations,
};

const t = ui[lang];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Fabián Marín — Senior Software Engineer</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #0a0a0a;
      --surface: #111111;
      --surface2: #181818;
      --border: #222222;
      --accent: #c8f03c;
      --text: #f0ede6;
      --muted: #666666;
      --muted2: #444444;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 999;
      opacity: 0.4;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.5rem 4rem;
      border-bottom: 1px solid var(--border);
      background: rgba(10,10,10,0.85);
      backdrop-filter: blur(12px);
    }

    .nav-logo {
      font-family: 'DM Mono', monospace;
      font-size: 0.8rem;
      color: var(--accent);
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 2.5rem;
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      font-family: 'DM Mono', monospace;
      font-size: 0.75rem;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--text); }

    /* Botón cambio de idioma */
    .lang-switch {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      color: var(--bg);
      background: var(--accent);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 0.4rem 0.9rem;
      transition: all 0.2s;
      border: 1px solid var(--accent);
    }

    .lang-switch:hover {
      background: transparent;
      color: var(--accent);
    }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      padding-top: 80px;
      position: relative;
      overflow: hidden;
    }

    .hero::after {
      content: '';
      position: absolute;
      top: -200px; right: -200px;
      width: 600px; height: 600px;
      background: radial-gradient(circle, rgba(200,240,60,0.06) 0%, transparent 70%);
      pointer-events: none;
    }

    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 6rem 4rem;
      border-right: 1px solid var(--border);
    }

    .hero-tag {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      color: var(--accent);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .hero-tag::before {
      content: '';
      width: 2rem;
      height: 1px;
      background: var(--accent);
    }

    h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3.5rem, 6vw, 6rem);
      font-weight: 900;
      line-height: 0.95;
      letter-spacing: -0.02em;
      margin-bottom: 2rem;
    }

    h1 span { color: var(--accent); font-style: italic; }

    .hero-bio {
      font-size: 1rem;
      line-height: 1.75;
      color: #888;
      max-width: 420px;
      margin-bottom: 3rem;
    }

    .hero-cta { display: flex; gap: 1rem; align-items: center; }

    .btn-primary {
      background: var(--accent);
      color: #0a0a0a;
      padding: 0.85rem 2rem;
      font-family: 'DM Mono', monospace;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      transition: all 0.2s;
    }

    .btn-primary:hover { background: var(--text); transform: translateY(-2px); }

    .btn-ghost {
      color: var(--muted);
      font-family: 'DM Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      border-bottom: 1px solid var(--muted2);
      padding-bottom: 2px;
      transition: all 0.2s;
    }

    .btn-ghost:hover { color: var(--text); border-color: var(--text); }

    .hero-right {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 4rem;
      position: relative;
    }

    .hero-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      margin-top: auto;
    }

    .stat {
      background: var(--bg);
      padding: 2rem;
      transition: background 0.2s;
    }

    .stat:hover { background: var(--surface); }

    .stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 3rem;
      font-weight: 900;
      color: var(--accent);
      line-height: 1;
      margin-bottom: 0.5rem;
    }

    .stat-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      color: var(--muted);
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .hero-location {
      position: absolute;
      top: 4rem; right: 4rem;
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      color: var(--muted);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      writing-mode: vertical-rl;
    }

    /* ── SKILLS ── */
    .skills-section {
      padding: 6rem 4rem;
      border-top: 1px solid var(--border);
    }

    .section-header {
      display: flex;
      align-items: baseline;
      gap: 1.5rem;
      margin-bottom: 4rem;
    }

    .section-num {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      color: var(--muted2);
      letter-spacing: 0.1em;
    }

    h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 3.5rem);
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .skills-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
    }

    .skill-card {
      background: var(--bg);
      padding: 2.5rem;
      transition: background 0.25s;
      position: relative;
      overflow: hidden;
    }

    .skill-card::before {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 0; height: 2px;
      background: var(--accent);
      transition: width 0.3s ease;
    }

    .skill-card:hover { background: var(--surface); }
    .skill-card:hover::before { width: 100%; }

    .skill-icon {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      color: var(--accent);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 1.25rem;
    }

    .skill-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    .skill-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

    .tag {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      color: var(--muted);
      background: var(--surface2);
      padding: 0.3rem 0.7rem;
      letter-spacing: 0.05em;
      border: 1px solid var(--border);
    }

    /* ── EXPERIENCE ── */
    .experience-section {
      padding: 6rem 4rem;
      border-top: 1px solid var(--border);
    }

    .exp-list { display: flex; flex-direction: column; }

    .exp-item {
      display: grid;
      grid-template-columns: 280px 1fr;
      border-top: 1px solid var(--border);
      padding: 3rem 0;
      cursor: default;
    }

    .exp-item:hover .exp-content { padding-left: 1.5rem; }

    .exp-meta { padding-right: 3rem; }

    .exp-company {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      color: var(--accent);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }

    .exp-period {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      color: var(--muted);
      letter-spacing: 0.08em;
    }

    .exp-content { transition: padding-left 0.3s ease; }

    .exp-role {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      font-weight: 700;
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    .exp-desc {
      font-size: 0.9rem;
      line-height: 1.8;
      color: #777;
      max-width: 640px;
    }

    /* ── EDUCATION & LANGUAGES ── */
    .bottom-section {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-top: 1px solid var(--border);
    }

    .edu-section {
      padding: 6rem 4rem;
      border-right: 1px solid var(--border);
    }

    .lang-section { padding: 6rem 4rem; }

    .edu-item {
      padding: 2rem 0;
      border-bottom: 1px solid var(--border);
    }

    .edu-item:first-child { padding-top: 0; }

    .edu-school {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      color: var(--accent);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 0.4rem;
    }

    .edu-degree {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 0.25rem;
    }

    .edu-period {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      color: var(--muted);
    }

    .lang-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.75rem 0;
      border-bottom: 1px solid var(--border);
    }

    .lang-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      font-weight: 700;
    }

    .lang-level {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      color: var(--accent);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: rgba(200,240,60,0.08);
      padding: 0.4rem 0.8rem;
      border: 1px solid rgba(200,240,60,0.2);
    }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid var(--border);
      padding: 5rem 4rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: end;
    }

    .footer-heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 3.5rem);
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 2rem;
      white-space: pre-line;
    }

    .footer-heading span { color: var(--accent); font-style: italic; }

    .contact-links { display: flex; flex-direction: column; gap: 1rem; }

    .contact-link {
      display: flex;
      align-items: center;
      gap: 1rem;
      text-decoration: none;
      color: var(--muted);
      font-family: 'DM Mono', monospace;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      transition: color 0.2s;
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border);
    }

    .contact-link:hover { color: var(--text); }

    .contact-link-label {
      font-size: 0.6rem;
      color: var(--muted2);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      min-width: 60px;
    }

    .footer-copy {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      color: var(--muted2);
      letter-spacing: 0.08em;
      text-align: right;
      align-self: end;
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .hero-tag  { animation: fadeUp 0.6s ease both; }
    h1         { animation: fadeUp 0.6s 0.1s ease both; }
    .hero-bio  { animation: fadeUp 0.6s 0.2s ease both; }
    .hero-cta  { animation: fadeUp 0.6s 0.3s ease both; }
    .hero-stats{ animation: fadeUp 0.6s 0.2s ease both; }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      nav { padding: 1.25rem 1.5rem; }
      .nav-links { display: none; }
      .hero { grid-template-columns: 1fr; }
      .hero-left { padding: 5rem 1.5rem 3rem; border-right: none; border-bottom: 1px solid var(--border); }
      .hero-right { padding: 2rem 1.5rem; }
      .hero-location { display: none; }
      .skills-section, .experience-section, .edu-section, .lang-section { padding: 4rem 1.5rem; }
      .skills-grid { grid-template-columns: 1fr; }
      .exp-item { grid-template-columns: 1fr; gap: 1rem; }
      .exp-meta { padding-right: 0; }
      .bottom-section { grid-template-columns: 1fr; }
      .edu-section { border-right: none; border-bottom: 1px solid var(--border); }
      footer { grid-template-columns: 1fr; padding: 3rem 1.5rem; }
      .footer-copy { text-align: left; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <div class="nav-logo">FM.dev</div>
    <div class="nav-right">
      <ul class="nav-links">
        <li><a href="#skills">{t.skills}</a></li>
        <li><a href="#experience">{t.experience}</a></li>
        <li><a href="#education">{t.education}</a></li>
        <li><a href="#contact">{t.cta}</a></li>
      </ul>
      <a href={otherUrl} class="lang-switch">{otherLang.toUpperCase()}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-left">
      <div class="hero-tag">{t.available}</div>
      <h1>Fabián<br/><span>Marín</span></h1>
      <p class="hero-bio">{t.bio}</p>
      <div class="hero-cta">
        <a href="#contact" class="btn-primary">{t.cta}</a>
        <a href="#experience" class="btn-ghost">{t.viewWork}</a>
        <a href="/resume.pdf" target="_blank" class="btn-ghost">{t.resume}</a>
      </div>
    </div>
    <div class="hero-right">
      <div class="hero-location">Medellín, Colombia</div>
      <div class="hero-stats">
        <div class="stat">
          <div class="stat-num">18+</div>
          <div class="stat-label">{t.yearsExp}</div>
        </div>
        <div class="stat">
          <div class="stat-num">5+</div>
          <div class="stat-label">{t.companies}</div>
        </div>
        <div class="stat">
          <div class="stat-num">2</div>
          <div class="stat-label">{t.languages}</div>
        </div>
        <div class="stat">
          <div class="stat-num">∞</div>
          <div class="stat-label">{t.coffee}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SKILLS -->
  <section class="skills-section" id="skills">
    <div class="section-header">
      <span class="section-num">01</span>
      <h2>{t.skills}</h2>
    </div>
    <div class="skills-grid">
      {skillsOrdered.map((skill) => (
        <div class="skill-card">
          <div class="skill-icon">{skill.data.category}</div>
          <div class="skill-title">{skill.data.title}</div>
          <div class="skill-tags">
            {skill.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section class="experience-section" id="experience">
    <div class="section-header">
      <span class="section-num">02</span>
      <h2>{t.experience}</h2>
    </div>
    <div class="exp-list">
      {await Promise.all(expOrdered.map(async (exp) => {
        const { Content } = await render(exp);
        return (
          <div class="exp-item">
            <div class="exp-meta">
              <div class="exp-company">{exp.data.company}</div>
              <div class="exp-period">{exp.data.startDate} → {exp.data.endDate ?? t.present}</div>
            </div>
            <div class="exp-content">
              <div class="exp-role">{exp.data.position}</div>
              <div class="exp-desc"><Content /></div>
            </div>
          </div>
        );
      }))}
    </div>
  </section>

  <!-- EDUCATION & LANGUAGES -->
  <div class="bottom-section" id="education">
    <div class="edu-section">
      <div class="section-header">
        <span class="section-num">03</span>
        <h2>{t.education}</h2>
      </div>
      {educationOrdered.map((edu) => (
        <div class="edu-item">
          <div class="edu-school">{edu.data.school}</div>
          <div class="edu-degree">{edu.data.degree}</div>
          <div class="edu-period">{edu.data.startDate} – {edu.data.endDate}</div>
        </div>
      ))}
    </div>

    <div class="lang-section">
      <div class="section-header">
        <span class="section-num">04</span>
        <h2>{t.langs}</h2>
      </div>
      <div class="lang-item">
        <div class="lang-name">{t.spanish}</div>
        <div class="lang-level">{t.native}</div>
      </div>
      <div class="lang-item">
        <div class="lang-name">{t.english}</div>
        <div class="lang-level">{t.advanced}</div>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <footer id="contact">
    <div>
      <div class="footer-heading">{t.together}</div>
      <div class="contact-links">
        <a href="mailto:famarin1k86@gmail.com" class="contact-link">
          <span class="contact-link-label">Email</span>
          famarin1k86@gmail.com
        </a>
        <a href="https://wa.me/573016442107" target="_blank" class="contact-link">
          <span class="contact-link-label">WhatsApp</span>
          +57 301 644 2107
        </a>
        <a href="https://www.linkedin.com/in/fabian-marin-36bab01a1/" target="_blank" class="contact-link">
          <span class="contact-link-label">LinkedIn</span>
          fabian-marin
        </a>
        <a href="https://github.com/fabian202" target="_blank" class="contact-link">
          <span class="contact-link-label">GitHub</span>
          fabian202
        </a>
        <a href="https://famarin.dev" target="_blank" class="contact-link">
          <span class="contact-link-label">Web</span>
          famarin.dev
        </a>
      </div>
    </div>
    <div class="footer-copy">
      © {currentYear} Fabián Marín<br/>
      Medellín, Colombia
    </div>
  </footer>

</body>
</html>
